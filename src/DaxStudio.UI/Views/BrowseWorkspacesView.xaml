                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>-->
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <Image Grid.Column="0" 
                                       Source="{DynamicResource workspaceDrawingImage}" 
                                       Width="20" Height="20" 
                                       Margin="0 0 12 0"
                                       VerticalAlignment="Center"/>
                                
                                <TextBlock Grid.Column="1" 
                                           Text="{Binding Name}"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"/>
                                
                                <Image Grid.Column="2" 
                                       Source="{DynamicResource premiumDrawingImage}" 
                                       Width="16" Height="16" 
                                       Margin="8 0 0 0" 
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsOnPremiumCapacity, Converter={StaticResource BoolToVisibilityConverter}}" 
                                       ToolTip="Premium Workspace"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Busy overlay -->
                <Border Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" 
                        IsHitTestVisible="{Binding IsBusy}"
                        Style="{StaticResource BusyPanel}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Style="{StaticResource MaterialDesignCircularProgressBar}" 
                            Height="60"
                            Width="60"
                            Margin="0 0 0 16"/>
                        <TextBlock Text="Loading workspaces..." 
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource Theme.Brush.Default.Fore}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Bottom Section: Account Info and Buttons -->
        <Grid Grid.Row="3" Margin="0 8 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Account Switcher -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="0">
                <Menu>
                    <MenuItem BorderBrush="{DynamicResource Theme.Brush.Control.Border}" 
                              BorderThickness="1" 
                              MinWidth="200"
                              Background="{DynamicResource Theme.Brush.Default.Back}"
                              Padding="8">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <!-- User Avatar or Default Icon -->
                                <Border Width="32" Height="32" 
                                        CornerRadius="16" 
                                        Background="{DynamicResource Theme.Brush.Muted.Back}"
                                        Margin="0 0 12 0"
                                        Visibility="{Binding HasAvatar, Converter={StaticResource BoolToNotCollapsedConverter}}">
                                    <Image Source="{DynamicResource userDrawingImage}" 
                                           Width="20" Height="20"/>
                                </Border>
                                <Image Source="{Binding UserAvatar}" 
                                       Width="32" Height="32" 
                                       Margin="0 0 12 0"
                                       Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Image.Clip>
                                        <EllipseGeometry Center="16,16" RadiusX="16" RadiusY="16"/>
                                    </Image.Clip>
                                </Image>
                                
                                <Grid>
                                    <TextBlock Text="{Binding AccountName}" 
                                               VerticalAlignment="Center"
                                               FontSize="13"
                                               Visibility="{Binding IsConnecting, Converter={StaticResource BoolToNotCollapsedConverter}}"/>
                                    
                                    <StackPanel Orientation="Horizontal" 
                                                Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ProgressBar
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource MaterialDesignCircularProgressBar}" 
                                            Height="20"
                                            Width="20" 
                                            Margin="0 0 8 0"/>
                                        <TextBlock Text="{Binding AccountStatus}" 
                                                   VerticalAlignment="Center"
                                                   FontSize="13"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </MenuItem.Header>
                        <MenuItem.Style>
                            <Style BasedOn="{StaticResource {x:Type MenuItem}}" TargetType="{x:Type MenuItem}">
                                <Setter Property="Border.CornerRadius" Value="8"/>
                            </Style>
                        </MenuItem.Style>
                        <MenuItem x:Name="SwitchAccountAsync" 
                                  Header="Switch User"
                                  Icon="{DynamicResource userDrawingImage}"/>
                    </MenuItem>
                </Menu>
            </StackPanel>
            
            <!-- Connect/Cancel Buttons -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Grid.Column="1"
                        VerticalAlignment="Center">
                <Button Content="Connect" 
                        HorizontalAlignment="Right" 
                        x:Name="Connect" 
                        IsEnabled="{Binding CanConnect}"  
                        Width="90" 
                        Height="32"
                        IsDefault="True"
                        Style="{DynamicResource AccentButtonStyle}"
                        VerticalAlignment="Bottom"/>
                
                <Button Content="Cancel"  
                        HorizontalAlignment="Right" 
                        Margin="8 0 0 0"
                        x:Name="Close" 
                        VerticalAlignment="Bottom" 
                        Width="90"
                        Height="32"
                        IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</ctrl:DaxStudioDialog>
